tests/test_packet.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/tests.dir/build.make CMakeFiles/tests.dir/tests/test_packet.cpp.i
.PHONY : tests/test_packet.cpp.i

tests/test_packet.s: tests/test_packet.cpp.s
.PHONY : tests/test_packet.s

# target to generate assembly for a file
tests/test_packet.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/tests.dir/build.make CMakeFiles/tests.dir/tests/test_packet.cpp.s
.PHONY : tests/test_packet.cpp.s

tests/test_state_machine.o: tests/test_state_machine.cpp.o
